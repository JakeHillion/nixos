{
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "* 2-5 * * *"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/modules/oci-containers/versions.json/"
      ],
      "matchStrings": [
        "\"(?<depName>[^\"]+)\":\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "rebaseWhen": "behind-base-branch",
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "automerge": true,
      "schedule": [
        "after 11pm on Monday",
        "after 11pm on Thursday"
      ]
    },
    {
      "matchManagers": [
        "gomod"
      ],
      "matchFileNames": [
        "pkgs/caddy-with-dns/**"
      ],
      "postUpgradeTasks": {
        "commands": [
          "sed -i 's|vendorHash = \"sha256-[^\"]*\"|vendorHash = \"sha256-AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=\"|' pkgs/caddy-with-dns/default.nix",
          "HASH=$(nix build --no-link .#caddy-with-dns 2>&1 | grep 'got:' | awk '{print $2}') && sed -i \"s|vendorHash = \\\"sha256-[^\\\"]*\\\"|vendorHash = \\\"$HASH\\\"|\" pkgs/caddy-with-dns/default.nix"
        ],
        "fileFilters": [
          "pkgs/caddy-with-dns/default.nix"
        ],
        "executionMode": "update"
      }
    }
  ],
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "docker:enableMajor"
  ]
}
